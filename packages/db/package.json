{
  "name": "@wedding/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "XDG_CACHE_HOME=../../.cache prisma generate && tsc",
    "db:generate": "XDG_CACHE_HOME=../../.cache prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "echo 'lint ok'"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^6.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
