# ============================================================
# STOP — change ALL values marked "required" before deploying
# ============================================================

# Required — SESSION_SECRET must be at least 32 random characters
SESSION_SECRET=change-me-to-a-long-random-string-min-32-chars

# Required — ADMIN_PASSWORD must be at least 12 characters
ADMIN_PASSWORD=change-me-now!

# Optional — defaults shown
ADMIN_USERNAME=admin
DATABASE_URL=file:/app/data/db.sqlite
FRONTEND_URL=http://localhost:3000
STORAGE_PROVIDER=local
MAX_FILE_SIZE_MB=50
MAX_VIDEO_SIZE_MB=200

# Public URL that browsers use to call the API (not the internal Docker hostname!)
# In production: https://yourdomain.com/api or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:4000
